COMPOSE_PROJECT_NAME=brasaller

CORS_ORIGINS=http://localhost:3000,http://localhost:4200
LOG_JSON=true
HTTP_ACCESS_LOG_ENABLED=true
JAVA_MAX_MEM_RATIO=75

DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=16
DB_ACQUISITION_TIMEOUT=5S
FLYWAY_MIGRATE_AT_START=true
SWAGGER_UI_ENABLED=true

AUTH_JWT_ISSUER=brasaller-auth
AUTH_JWT_AUDIENCE=brasaller-platform
AUTH_JWT_SECRET=dev-only-change-me-please-32-bytes-minimum
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
INTERNAL_SERVICE_TOKEN=dev-internal-token-change-me
GOOGLE_CLIENT_ID=not-configured
GOOGLE_REDIRECT_URI=http://localhost:8085/auth/oauth/google/callback

GATEWAY_API_PORT=8080
CORE_SERVICE_PORT=8081
BILLING_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083
USER_SERVICE_PORT=8084
AUTH_SERVICE_PORT=8085
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ROOT_URL=http://localhost:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

GATEWAY_DB_PORT=5432
GATEWAY_DB_NAME=gateway_api
GATEWAY_DB_USERNAME=gateway_api
GATEWAY_DB_PASSWORD=gateway_api_password

CORE_DB_PORT=5433
CORE_DB_NAME=core_service
CORE_DB_USERNAME=core_service
CORE_DB_PASSWORD=core_service_password

BILLING_DB_PORT=5434
BILLING_DB_NAME=billing_service
BILLING_DB_USERNAME=billing_service
BILLING_DB_PASSWORD=billing_service_password

NOTIFICATION_DB_PORT=5435
NOTIFICATION_DB_NAME=notification_service
NOTIFICATION_DB_USERNAME=notification_service
NOTIFICATION_DB_PASSWORD=notification_service_password

USER_DB_PORT=5436
USER_DB_NAME=user_service
USER_DB_USERNAME=user_service
USER_DB_PASSWORD=user_service_password

AUTH_DB_PORT=5437
AUTH_DB_NAME=auth_service
AUTH_DB_USERNAME=auth_service
AUTH_DB_PASSWORD=auth_service_password
