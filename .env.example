COMPOSE_PROJECT_NAME=brasaller

CORS_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:8080,https://app.apidog.com,https://aistudio.google.com
LOG_JSON=true
HTTP_ACCESS_LOG_ENABLED=true
JAVA_MAX_MEM_RATIO=75

DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=16
DB_ACQUISITION_TIMEOUT=5S
FLYWAY_MIGRATE_AT_START=true
SWAGGER_UI_ENABLED=true
GATEWAY_DOWNSTREAM_CONNECT_TIMEOUT_MS=2000
GATEWAY_DOWNSTREAM_READ_TIMEOUT_MS=30000
AUTH_SERVICE_OPENAPI_URL=http://localhost:8085/q/openapi
USER_SERVICE_OPENAPI_URL=http://localhost:8084/q/openapi
CORE_SERVICE_OPENAPI_URL=http://localhost:8081/q/openapi
BILLING_SERVICE_OPENAPI_URL=http://localhost:8082/q/openapi
NOTIFICATION_SERVICE_OPENAPI_URL=http://localhost:8083/q/openapi

AUTH_JWT_ISSUER=brasaller-auth
AUTH_JWT_AUDIENCE=brasaller-platform
AUTH_JWT_SECRET=dev-only-change-me-please-32-bytes-minimum
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
INTERNAL_SERVICE_TOKEN=dev-internal-token-change-me
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
BRASALLER_KAFKA_TOPIC_NOTIFICATION_NEW_SALE=brasaller.notifications.new-sale.v1
BRASALLER_KAFKA_TOPIC_NOTIFICATION_NEW_SALE_DLQ=brasaller.notifications.new-sale.dlq.v1
BRASALLER_KAFKA_TOPIC_NOTIFICATION_NEW_SALE_SUMMARY=brasaller.analytics.tenant-new-sale-summary.v1
KAFKA_NOTIFICATION_GROUP_ID=notification-service
KAFKA_STREAMS_APPLICATION_ID=notification-service-new-sale-streams
KAFKA_STREAMS_APPLICATION_SERVER=notification-service:8080
KAFKA_STREAMS_STATE_DIR=/deployments/kafka-streams
KEYCLOAK_PORT=8086
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_BASE_URL=http://localhost:8086
KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
KEYCLOAK_PUBLIC_BASE_URL=http://localhost:8086
KEYCLOAK_REALM=brasaller
KEYCLOAK_CLIENT_ID=auth-service
KEYCLOAK_CLIENT_SECRET=not-configured
KEYCLOAK_REDIRECT_URI=http://localhost:3000/auth/callback
KEYCLOAK_SCOPE=openid email profile
KEYCLOAK_REQUIRE_EMAIL_VERIFIED=false
KEYCLOAK_GOOGLE_CLIENT_ID=not-configured
KEYCLOAK_GOOGLE_CLIENT_SECRET=not-configured
KEYCLOAK_GOOGLE_PROMPT=
KEYCLOAK_GOOGLE_HOSTED_DOMAIN=

GATEWAY_API_PORT=8080
CORE_SERVICE_PORT=8081
BILLING_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083
USER_SERVICE_PORT=8084
AUTH_SERVICE_PORT=8085
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ROOT_URL=http://localhost:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

GATEWAY_DB_PORT=5432
GATEWAY_DB_NAME=gateway_api
GATEWAY_DB_USERNAME=gateway_api
GATEWAY_DB_PASSWORD=gateway_api_password

CORE_DB_PORT=5433
CORE_DB_NAME=core_service
CORE_DB_USERNAME=core_service
CORE_DB_PASSWORD=core_service_password

BILLING_DB_PORT=5434
BILLING_DB_NAME=billing_service
BILLING_DB_USERNAME=billing_service
BILLING_DB_PASSWORD=billing_service_password

NOTIFICATION_DB_PORT=5435
NOTIFICATION_DB_NAME=notification_service
NOTIFICATION_DB_USERNAME=notification_service
NOTIFICATION_DB_PASSWORD=notification_service_password
NOTIFICATION_MAIL_FROM=no-reply@braseller.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_MOCK=true
NOTIFICATION_MONTHLY_CLOSING_CRON=0 0 8 1 * ?
NOTIFICATION_ML_PAYMENT_RELEASE_CRON=0 0/30 * * * ?
NOTIFICATION_WEEKLY_ACCOUNTANT_REPORT_CRON=0 0 8 ? * MON

USER_DB_PORT=5436
USER_DB_NAME=user_service
USER_DB_USERNAME=user_service
USER_DB_PASSWORD=user_service_password

AUTH_DB_PORT=5437
AUTH_DB_NAME=auth_service
AUTH_DB_USERNAME=auth_service
AUTH_DB_PASSWORD=auth_service_password
