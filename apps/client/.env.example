# Public URL of the Next.js application, without a trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal/server-side URL used by Next.js to call the Gateway.
GATEWAY_URL=https://gateway-api.salmonrock-4d3f2812.brazilsouth.azurecontainerapps.io

# Only define this when browser-side code truly needs direct Gateway access.
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# Mercado Livre application ID. This value is public by OAuth design.
NEXT_PUBLIC_MERCADO_LIVRE_CLIENT_ID=4587994283757685

# Exposes the Sandbox connector and allows its synthetic data in reports.
# Keep disabled in production unless the tenant is intended for QA/demo use.
ENABLE_TEST_CONNECTOR=false

# Register this exact local callback in Mercado Livre Developers:
# http://localhost:3000/pt-BR/conectores/callback/mercado-livre
#
# Production example:
# https://DOMINIO_PROD/pt-BR/conectores/callback/mercado-livre
